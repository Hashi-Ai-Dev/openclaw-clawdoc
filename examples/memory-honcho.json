{
  "memory": {
    "backend": "qmd",
    "citations": "auto"
  },
  "plugins": {
    "slots": {
      "memory": "openclaw-honcho"
    },
    "entries": {
      "openclaw-honcho": {
        "enabled": true,
        "config": {
          "workspaceId": "your-workspace-id",
          "baseUrl": "https://your-honcho-host.com"
        }
      }
    }
  }
}
